{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "selections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entity_id": {
            "type": "string"
          },
          "selected_id": {
            "type": "string",
            "description": "Zero or one RxCUI chosen only from the provided candidate list."
          },
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "entity_id",
          "selected_id",
          "reason"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "selections"
  ],
  "additionalProperties": false
}
