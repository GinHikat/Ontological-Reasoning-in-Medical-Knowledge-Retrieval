GOOGLE_API_CREDS=secrets/ggsheet_credentials.json
GOOGLE_SHEET_ID=sheet_id_here
GOOGLE_DRIVE_ID=drive_id_here

OPENAI_API_KEY=open_ai_key_here
GOOGLE_API_KEY=google_ai_key_here
GOOGLE_GENAI_USE_VERTEXAI=false

NEO4J_USERNAME=neo4j_username
NEO4J_URI=uri_here
NEO4J_AUTH=password_here
NEO4J_DATABASE=database_here

HUGGINGFACE_API_KEY=hf_key_here
HF_HUB_DISABLE_SYMLINKS=1

DATA_DIR=data_directory_here

# --- openrouter_schema_teacher (EXTERNAL_API_DIAGNOSTIC_ONLY) ---
OPENROUTER_API_KEY=
# Optional second key; rotated automatically on HTTP 429
OPENROUTER_API_KEY_FALLBACK=

# Profile: default | free_first
# free_first (active for cheap diagnostic): separate dirs + fixed free models:
#   tencent/hy3:free
#   nvidia/nemotron-3-ultra-550b-a55b:free
#   poolside/laguna-m.1:free
#   judge: tencent/hy3:free
OPENROUTER_TEACHER_PROFILE=free_first

# !!! TODO BEFORE PAID / profile=default RUN !!!
# Leave these empty until the user picks NEW paid model IDs.
# Do NOT reuse old opus/gemini/gpt-5.5 placeholders without asking.
# Comma-separated model IDs (used only when OPENROUTER_TEACHER_PROFILE=default).
OPENROUTER_EXTRACTOR_MODELS=
OPENROUTER_JUDGE_MODEL=

# Full run gate for paid profile; free_first may proceed with $0 spend.
OPENROUTER_BUDGET_USD=

OPENROUTER_MAX_CONCURRENCY=1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=300
OPENROUTER_MAX_RETRIES=8

# --- openrouter_schema_teacher_reduced (EXTERNAL_API_DIAGNOSTIC_ONLY) ---
# One primary extractor + largest model as conditional judge only.
# Defaults from offline ablation / largest configured free_first model:
OPENROUTER_REDUCED_EXTRACTOR_MODEL=tencent/hy3:free
OPENROUTER_REDUCED_JUDGE_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Optional explicit fallback (disabled unless ALLOW_JUDGE_FALLBACK=true)
OPENROUTER_REDUCED_JUDGE_FALLBACK_MODEL=
OPENROUTER_REDUCED_ALLOW_JUDGE_FALLBACK=false

OPENROUTER_REDUCED_MICROBATCH_SIZE=1
OPENROUTER_REDUCED_DOCUMENT_WORKERS=1
OPENROUTER_REDUCED_GLOBAL_CONCURRENCY=1
OPENROUTER_REDUCED_PER_MODEL_CONCURRENCY=1

OPENROUTER_REDUCED_MAX_REQUESTS_PER_MINUTE=
OPENROUTER_REDUCED_MIN_REQUEST_INTERVAL_SECONDS=3
OPENROUTER_REDUCED_JITTER_SECONDS=2

OPENROUTER_REDUCED_ENABLE_RISK_REVIEW=true
OPENROUTER_REDUCED_ENABLE_CANDIDATE_JUDGE=true
OPENROUTER_REDUCED_RISK_THRESHOLD=3
OPENROUTER_REDUCED_CANDIDATE_BATCH_SIZE=15
OPENROUTER_REDUCED_BUDGET_USD=

# Deterministic ontology acceptance (from offline score distributions)
OPENROUTER_REDUCED_DIAGNOSIS_TOP_THRESHOLD=0.85
OPENROUTER_REDUCED_DIAGNOSIS_MARGIN_THRESHOLD=0.08
OPENROUTER_REDUCED_DRUG_TOP_THRESHOLD=0.95
OPENROUTER_REDUCED_DRUG_MARGIN_THRESHOLD=0.08
