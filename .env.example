GOOGLE_API_CREDS=secrets/ggsheet_credentials.json
GOOGLE_SHEET_ID=sheet_id_here
GOOGLE_DRIVE_ID=drive_id_here

OPENAI_API_KEY=open_ai_key_here
GOOGLE_API_KEY=google_ai_key_here
GOOGLE_GENAI_USE_VERTEXAI=false

NEO4J_USERNAME=neo4j_username
NEO4J_URI=uri_here
NEO4J_AUTH=password_here
NEO4J_DATABASE=database_here

HUGGINGFACE_API_KEY=hf_key_here
HF_HUB_DISABLE_SYMLINKS=1

DATA_DIR=data_directory_here

# --- openrouter_schema_teacher (EXTERNAL_API_DIAGNOSTIC_ONLY) ---
OPENROUTER_API_KEY=
# Optional second key; rotated automatically on HTTP 429
OPENROUTER_API_KEY_FALLBACK=

# Profile: default | free_first
# free_first (active for cheap diagnostic): separate dirs + fixed free models:
#   tencent/hy3:free
#   nvidia/nemotron-3-ultra-550b-a55b:free
#   poolside/laguna-m.1:free
#   judge: tencent/hy3:free
OPENROUTER_TEACHER_PROFILE=free_first

# !!! TODO BEFORE PAID / profile=default RUN !!!
# Leave these empty until the user picks NEW paid model IDs.
# Do NOT reuse old opus/gemini/gpt-5.5 placeholders without asking.
# Comma-separated model IDs (used only when OPENROUTER_TEACHER_PROFILE=default).
OPENROUTER_EXTRACTOR_MODELS=
OPENROUTER_JUDGE_MODEL=

# Full run gate for paid profile; free_first may proceed with $0 spend.
OPENROUTER_BUDGET_USD=

OPENROUTER_MAX_CONCURRENCY=1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=300
OPENROUTER_MAX_RETRIES=8
